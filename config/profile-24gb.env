# 24 GB MacBook Pro local coding profile.
# Edit this file first when upgrading the model, context, ports, MCP paths, or
# LM Studio runtime packages. Scripts and smoke tests source these values.

PROFILE_NAME="24GB MacBook Pro local coding profile"
PROFILE_NOTES="Concrete /Users/ohmz setup for LM Studio + OpenCode Desktop on Apple Silicon with about 24 GB RAM."
TARGET_USER="ohmz"
TARGET_HOME="/Users/ohmz"
EXPECTED_ARCH="arm64"
MIN_MEM_BYTES="24000000000"
MAX_MEM_BYTES="30000000000"

LMS="/Applications/LM Studio.app/Contents/Resources/app/.webpack/lms"
LMSTUDIO_HOST="127.0.0.1"
LMSTUDIO_PORT="1234"
LMSTUDIO_BASE_URL="http://127.0.0.1:1234/v1"
LMSTUDIO_MODELS_URL="http://127.0.0.1:1234/api/v0/models"
LMSTUDIO_EMBEDDING_URL="http://127.0.0.1:1234/v1/embeddings"

CHAT_ID="qwen3.6-27b"
CHAT_MODEL_KEY="qwen3.6-27b"
CHAT_MODEL_PATH="NexVeridian/Qwen3.6-27B-3bit"
CHAT_MODEL_FORMAT="safetensors"
CHAT_MODEL_QUANTIZATION="3bit"
CHAT_MODEL_DISPLAY="Qwen3.6 27B 3-bit MLX (local, 12K tools)"
CHAT_CONTEXT="12288"
CHAT_OUTPUT="768"
CHAT_PARALLEL="1"
CHAT_GPU="max"
CHAT_TTL="86400"

EMBED_ID="text-embedding-nomic-embed-text-v1.5"
EMBED_MODEL_KEY="text-embedding-nomic-embed-text-v1.5"
EMBED_MODEL_PATH="nomic-ai/nomic-embed-text-v1.5-GGUF/nomic-embed-text-v1.5.Q4_K_M.gguf"
EMBED_TTL="86400"

OPENCODE_PROVIDER="lmstudio"
OPENCODE_MODEL="lmstudio/qwen3.6-27b"
OPENCODE_CONFIG="$TARGET_HOME/.config/opencode/opencode.json"
OPENCODE_CONFIG_DIR="$TARGET_HOME/.config/opencode"
OPENCODE_DESKTOP_STATE="$TARGET_HOME/Library/Application Support/ai.opencode.desktop/opencode.global.dat"
OPENCODE_INDEX_ROOTS="auto"
OPENCODE_INDEX_AUTODISCOVER="1"
OPENCODE_INDEX_BACKGROUND="1"
OPENCODE_INDEX_BACKGROUND_SECONDS="300"
OPENCODE_INDEX_DB="$TARGET_HOME/.cache/opencode/local-code-index.sqlite3"
OPENCODE_DEV_ROOTS="auto"

SOURCEKIT_LSP="/usr/bin/sourcekit-lsp"
DEVELOPER_DIR="/Applications/Xcode.app/Contents/Developer"
TOOLCHAINS="com.apple.dt.toolchain.XcodeDefault"

MLX_RUNTIME_VERSION="1.8.5"
MLX_RUNTIME_NAX="mlx-llm-mac-arm64-apple-metal-nax-advsimd"
MLX_RUNTIME_STANDARD="mlx-llm-mac-arm64-apple-metal-advsimd"
LMSTUDIO_BACKENDS_DIR="$TARGET_HOME/.lmstudio/extensions/backends"
LMSTUDIO_BACKENDS_CACHE_DIR="$TARGET_HOME/.cache/lm-studio/downloads/backends"
LMSTUDIO_EXTENSION_MASTER_LIST="https://extensions.lmstudio.ai/master-lists-v2/backends-master-list-stable.json"

LMSTUDIO_EXTENSION_CPYTHON_NAME="vendor-_amphibian-cpython3.11-mac-arm64@10"
LMSTUDIO_EXTENSION_CPYTHON_URL="https://extensions.lmstudio.ai/vendor-_amphibian-cpython3.11-mac-arm64%4010.tar.gz"
LMSTUDIO_EXTENSION_CPYTHON_SHA256="9f69bc1f2a457a5d94d46913bbb6e0f4b9b2810db791457396f2827b218b8310"

LMSTUDIO_EXTENSION_APP_MLX_MAC14_NAME="vendor-_amphibian-app-mlx-generate-mac14-arm64@29"
LMSTUDIO_EXTENSION_APP_MLX_MAC14_URL="https://extensions.lmstudio.ai/vendor-_amphibian-app-mlx-generate-mac14-arm64%4029.tar.gz"
