# 96 GB Ubuntu NVIDIA local agentic coding profile.
# This is an opt-in Linux/GGUF profile. It preserves the same OpenCode
# local-coder workflow while changing the runtime target from Mac MLX to
# LM Studio's llama.cpp/GGUF runtime on an RTX 3090.

PROFILE_NAME="96GB Ubuntu RTX 3090 Qwen3.6 GGUF Q5_K_XL agentic coding profile"
PROFILE_SLUG="96gb-ubuntu-nvidia"
PROFILE_OS="linux"
PROFILE_NOTES="Concrete OpenCode + LM Studio setup for Ubuntu x86_64 with 96 GB RAM, RTX 3090 24 GB VRAM, and one visible local-coder model."
TARGET_USER="ohmz"
TARGET_HOME="/home/ohmz"
EXPECTED_ARCH="x86_64"
EXPECTED_MEM_BYTES="103079215104"
MIN_MEM_BYTES="90000000000"
MAX_MEM_BYTES="120000000000"
EXPECTED_GPU_VENDOR="NVIDIA"
EXPECTED_GPU_MODEL="RTX 3090"
EXPECTED_VRAM_GB="24"

# On Linux, run LM Studio once so the bundled lms CLI is bootstrapped into PATH.
LMS="lms"
LMSTUDIO_HOST="127.0.0.1"
LMSTUDIO_PORT="1234"
LMSTUDIO_BASE_URL="http://127.0.0.1:1234/v1"
LMSTUDIO_MODELS_URL="http://127.0.0.1:1234/api/v0/models"
LMSTUDIO_EMBEDDING_URL="http://127.0.0.1:1234/v1/embeddings"
LMSTUDIO_VERIFIED_VERSION="0.4.15+2"
OPENCODE_VERIFIED_VERSION="1.15.12"

CHAT_ID="local-coder"
CHAT_GET_REF="https://huggingface.co/unsloth/Qwen3.6-27B-GGUF@UD-Q5_K_XL"
CHAT_MODEL_KEY="unsloth/Qwen3.6-27B-GGUF@UD-Q5_K_XL"
CHAT_MODEL_INDEXED_IDENTIFIER="unsloth/Qwen3.6-27B-GGUF"
CHAT_MODEL_PATH="unsloth/Qwen3.6-27B-GGUF/Qwen3.6-27B-UD-Q5_K_XL.gguf"
CHAT_MODEL_FILENAME="Qwen3.6-27B-UD-Q5_K_XL.gguf"
CHAT_MODEL_HF_REPO="unsloth/Qwen3.6-27B-GGUF"
CHAT_MODEL_HF_QUANT="UD-Q5_K_XL"
CHAT_MODEL_FORMAT="gguf"
CHAT_MODEL_QUANTIZATION="UD-Q5_K_XL"
CHAT_MODEL_SIZE_GB="20"
CHAT_MODEL_SHA256="ac310abf2895aa397121bad6c0be89466af41f0f1606a21c1131b110eeb19d0e"
CHAT_MODEL_MIN_SYSTEM_MEMORY_GB="32"
CHAT_MODEL_MIN_VRAM_GB="24"
CHAT_MODEL_DISPLAY="Qwen3.6 27B GGUF UD-Q5_K_XL (RTX 3090, 16K)"
CHAT_CONTEXT="16384"
CHAT_CONTEXT_FALLBACK_1="12288"
CHAT_CONTEXT_FALLBACK_2="8192"
CHAT_OUTPUT="4096"
CHAT_PARALLEL="1"
CHAT_GPU="max"
CHAT_TTL="3600"

EMBED_ID="text-embedding-nomic-embed-text-v1.5"
EMBED_MODEL_KEY="text-embedding-nomic-embed-text-v1.5"
EMBED_MODEL_PATH="nomic-ai/nomic-embed-text-v1.5-GGUF/nomic-embed-text-v1.5.Q4_K_M.gguf"
EMBED_DIMENSIONS="768"
EMBED_TTL="3600"

OPENCODE_PROVIDER="lmstudio"
OPENCODE_MODEL="lmstudio/local-coder"
OPENCODE_CONFIG="$TARGET_HOME/.config/opencode/opencode.json"
OPENCODE_CONFIG_DIR="$TARGET_HOME/.config/opencode"
OPENCODE_QWEN_INSTRUCTIONS="$TARGET_HOME/.config/opencode/qwen36-instructions.md"
OPENCODE_WORKFLOW_INSTRUCTIONS="$TARGET_HOME/.config/opencode/local-coding-workflow.md"
OPENCODE_DESKTOP_STATE="$TARGET_HOME/.config/ai.opencode.desktop/opencode.global.dat"
OPENCODE_INDEX_ROOTS="auto"
OPENCODE_INDEX_AUTODISCOVER="1"
OPENCODE_INDEX_BACKGROUND="1"
OPENCODE_INDEX_BACKGROUND_SECONDS="300"
OPENCODE_INDEX_AUTO_SYNC_SECONDS="300"
OPENCODE_INDEX_DB="$TARGET_HOME/.cache/opencode/local-code-index.sqlite3"
OPENCODE_DEV_ROOTS="auto"
OPENCODE_COMPACTION_RESERVED="10000"
OPENCODE_BACKUP_CONFIG="${OPENCODE_BACKUP_CONFIG:-config/opencode-96gb-ubuntu-nvidia.json}"
OPENCODE_ENSURE_MODELS_SCRIPT="${OPENCODE_ENSURE_MODELS_SCRIPT:-scripts/ensure-lmstudio-models-linux.sh}"

LOCAL_DEV_COMMAND_TIMEOUT="120"
LOCAL_DEV_MAX_TIMEOUT="600"
LOCAL_DEV_MAX_OUTPUT_CHARS="24000"
LOCAL_DEV_MAX_TREE_ENTRIES="400"

OPENCODE_ENABLE_EXA="1"
OPENCODE_EXPERIMENTAL_LSP_TOOL="true"
OPENCODE_LAUNCH_ENV="$TARGET_HOME/.config/opencode/opencode-launch-env-linux.sh"
OPENCODE_LAUNCH_AGENT_LABEL="opencode-linux-env"
OPENCODE_LAUNCH_AGENT_PLIST="$TARGET_HOME/.config/opencode/opencode-linux-env.conf"

TYPESCRIPT_LSP_COMMAND="npx --yes typescript-language-server --stdio"
ESLINT_LSP_COMMAND="npx --yes vscode-eslint-language-server --stdio"
