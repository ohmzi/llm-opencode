# 96 GB Ubuntu NVIDIA local agentic coding profile.
# This is an opt-in Linux/GGUF profile. It preserves the same OpenCode
# local-coder workflow while changing the runtime target from Mac MLX to
# Lucebox DFlash on an RTX 3090. LM Studio stays available for embeddings
# and explicit rollback only.

PROFILE_NAME="96GB Ubuntu RTX 3090 Lucebox Qwen3.6 DFlash + LM Studio embeddings profile"
PROFILE_SLUG="96gb-ubuntu-nvidia"
PROFILE_OS="linux"
PROFILE_NOTES="Concrete OpenCode + Lucebox setup for Ubuntu x86_64 with 96 GB RAM, RTX 3090 24 GB VRAM, Lucebox as the main Qwen model, and LM Studio as the embedding/rollback service."
TARGET_USER="ohmz"
TARGET_HOME="/home/ohmz"
EXPECTED_ARCH="x86_64"
EXPECTED_MEM_BYTES="103079215104"
MIN_MEM_BYTES="90000000000"
MAX_MEM_BYTES="120000000000"
EXPECTED_GPU_VENDOR="NVIDIA"
EXPECTED_GPU_MODEL="RTX 3090"
EXPECTED_VRAM_GB="24"

# On Linux, run LM Studio once so the bundled lms CLI is bootstrapped into PATH.
LMS="lms"
LMSTUDIO_HOST="127.0.0.1"
LMSTUDIO_PORT="1234"
LMSTUDIO_BASE_URL="http://127.0.0.1:1234/v1"
LMSTUDIO_MODELS_URL="http://127.0.0.1:1234/api/v0/models"
LMSTUDIO_EMBEDDING_URL="http://127.0.0.1:1234/v1/embeddings"
LMSTUDIO_VERIFIED_VERSION="0.4.15+2"
OPENCODE_VERIFIED_VERSION="1.15.12"

LUCEBOX_HOME="/home/ohmz/StudioProjects/lucebox-hub"
LUCEBOX_HOST="127.0.0.1"
LUCEBOX_PORT="18080"
LUCEBOX_PROXY_HOST="$LUCEBOX_HOST"
LUCEBOX_PROXY_PORT="$LUCEBOX_PORT"
LUCEBOX_BACKEND_HOST="127.0.0.1"
LUCEBOX_BACKEND_PORT="18081"
LUCEBOX_BASE_URL="http://$LUCEBOX_PROXY_HOST:$LUCEBOX_PROXY_PORT/v1"
LUCEBOX_HEALTH_URL="http://$LUCEBOX_PROXY_HOST:$LUCEBOX_PROXY_PORT/health"
LUCEBOX_PROPS_URL="http://$LUCEBOX_PROXY_HOST:$LUCEBOX_PROXY_PORT/props"
LUCEBOX_BACKEND_URL="http://$LUCEBOX_BACKEND_HOST:$LUCEBOX_BACKEND_PORT"
LUCEBOX_BACKEND_BASE_URL="$LUCEBOX_BACKEND_URL/v1"
LUCEBOX_BACKEND_HEALTH_URL="$LUCEBOX_BACKEND_URL/health"
LUCEBOX_BACKEND_PROPS_URL="$LUCEBOX_BACKEND_URL/props"
LUCEBOX_PROVIDER="lucebox"
LUCEBOX_MODEL_ID="luce-dflash"
LUCEBOX_MODEL="lucebox/luce-dflash"
LUCEBOX_MODEL_DISPLAY="Lucebox DFlash Qwen3.6 27B Q4_K_M (RTX 3090, 32K)"
LUCEBOX_SERVER_BIN="$LUCEBOX_HOME/server/build/dflash_server"
LUCEBOX_TARGET="$LUCEBOX_HOME/server/models/Qwen3.6-27B-Q4_K_M.gguf"
LUCEBOX_DRAFT="$LUCEBOX_HOME/server/models/draft/dflash-draft-3.6-q4_k_m.gguf"
LUCEBOX_TARGET_REPO="unsloth/Qwen3.6-27B-GGUF"
LUCEBOX_TARGET_FILE="Qwen3.6-27B-Q4_K_M.gguf"
LUCEBOX_DRAFT_REPO="Lucebox/Qwen3.6-27B-DFlash-GGUF"
LUCEBOX_DRAFT_FILE="dflash-draft-3.6-q4_k_m.gguf"
LUCEBOX_CONTEXT="32768"
LUCEBOX_OUTPUT="4096"
LUCEBOX_DDTREE_BUDGET="22"
LUCEBOX_FA_WINDOW="2048"
LUCEBOX_CACHE_TYPE_K="tq3_0"
LUCEBOX_CACHE_TYPE_V="tq3_0"
LUCEBOX_EXTRA_ARGS="--lazy-draft"
LUCEBOX_SERVICE_NAME="lucebox-dflash"
LUCEBOX_PROXY_SERVICE_NAME="lucebox-dflash-proxy"
LUCEBOX_PROXY_SCRIPT="$TARGET_HOME/.config/opencode/lucebox-autowake-proxy.py"
LUCEBOX_IDLE_UNLOAD_SECONDS="3600"
LUCEBOX_START_TIMEOUT_SECONDS="900"
LUCEBOX_PROXY_REQUEST_TIMEOUT_SECONDS="900"
LUCEBOX_IDLE_POLL_SECONDS="15"

CHAT_ID="local-coder"
CHAT_GET_REF="https://huggingface.co/unsloth/Qwen3.6-27B-GGUF/resolve/main/Qwen3.6-27B-UD-Q5_K_XL.gguf"
CHAT_MODEL_KEY="unsloth/qwen3.6-27b"
CHAT_MODEL_INDEXED_IDENTIFIER="unsloth/qwen3.6-27b"
CHAT_MODEL_PATH="unsloth/Qwen3.6-27B-GGUF/Qwen3.6-27B-UD-Q5_K_XL.gguf"
CHAT_MODEL_FILENAME="Qwen3.6-27B-UD-Q5_K_XL.gguf"
CHAT_MODEL_HF_REPO="unsloth/Qwen3.6-27B-GGUF"
CHAT_MODEL_HF_QUANT="UD-Q5_K_XL"
CHAT_MODEL_FORMAT="gguf"
CHAT_MODEL_QUANTIZATION="UD-Q5_K_XL"
CHAT_MODEL_SIZE_GB="20"
CHAT_MODEL_SHA256="ac310abf2895aa397121bad6c0be89466af41f0f1606a21c1131b110eeb19d0e"
CHAT_MODEL_MIN_SYSTEM_MEMORY_GB="32"
CHAT_MODEL_MIN_VRAM_GB="24"
CHAT_MODEL_DISPLAY="Qwen3.6 27B GGUF UD-Q5_K_XL (RTX 3090, 16K)"
CHAT_CONTEXT="16384"
CHAT_CONTEXT_FALLBACK_1="12288"
CHAT_CONTEXT_FALLBACK_2="8192"
CHAT_OUTPUT="4096"
CHAT_PARALLEL="1"
CHAT_GPU="max"
CHAT_TTL="3600"

EMBED_ID="text-embedding-nomic-embed-text-v1.5"
EMBED_MODEL_KEY="text-embedding-nomic-embed-text-v1.5"
EMBED_MODEL_PATH="nomic-ai/nomic-embed-text-v1.5-GGUF/nomic-embed-text-v1.5.Q4_K_M.gguf"
EMBED_DIMENSIONS="768"
EMBED_GPU="off"
EMBED_TTL="3600"

OPENCODE_PROVIDER="lucebox"
OPENCODE_MODEL="$LUCEBOX_MODEL"
OPENCODE_FALLBACK_PROVIDER="lmstudio"
OPENCODE_FALLBACK_MODEL="lmstudio/local-coder"
OPENCODE_CONFIG="$TARGET_HOME/.config/opencode/opencode.json"
OPENCODE_CONFIG_DIR="$TARGET_HOME/.config/opencode"
OPENCODE_QWEN_INSTRUCTIONS="$TARGET_HOME/.config/opencode/qwen36-instructions.md"
OPENCODE_WORKFLOW_INSTRUCTIONS="$TARGET_HOME/.config/opencode/local-coding-workflow.md"
OPENCODE_DESKTOP_STATE="$TARGET_HOME/.config/ai.opencode.desktop/opencode.global.dat"
OPENCODE_INDEX_ROOTS="auto"
OPENCODE_INDEX_AUTODISCOVER="1"
OPENCODE_INDEX_BACKGROUND="1"
OPENCODE_INDEX_BACKGROUND_SECONDS="300"
OPENCODE_INDEX_AUTO_SYNC_SECONDS="300"
OPENCODE_INDEX_DB="$TARGET_HOME/.cache/opencode/local-code-index.sqlite3"
OPENCODE_DEV_ROOTS="auto"
OPENCODE_COMPACTION_RESERVED="10000"
OPENCODE_BACKUP_CONFIG="${OPENCODE_BACKUP_CONFIG:-config/opencode-96gb-ubuntu-nvidia.json}"
OPENCODE_ENSURE_MODELS_SCRIPT="${OPENCODE_ENSURE_MODELS_SCRIPT:-scripts/ensure-lmstudio-models-linux.sh}"
OPENCODE_LUCEBOX_ENSURE_SCRIPT="${OPENCODE_LUCEBOX_ENSURE_SCRIPT:-scripts/ensure-lucebox-linux.sh}"
LMSTUDIO_ENSURE_MODELS_SCRIPT="$OPENCODE_CONFIG_DIR/ensure-lmstudio-models-linux.sh"

# Normal mode keeps LM Studio chat unloaded so Lucebox owns the RTX 3090.
# Set this to 1 only when intentionally testing rollback to lmstudio/local-coder.
LMSTUDIO_LOAD_CHAT_ROLLBACK="${LMSTUDIO_LOAD_CHAT_ROLLBACK:-0}"

LOCAL_DEV_COMMAND_TIMEOUT="120"
LOCAL_DEV_MAX_TIMEOUT="600"
LOCAL_DEV_MAX_OUTPUT_CHARS="24000"
LOCAL_DEV_MAX_TREE_ENTRIES="400"

OPENCODE_ENABLE_EXA="1"
OPENCODE_EXPERIMENTAL_LSP_TOOL="true"
OPENCODE_LAUNCH_ENV="$TARGET_HOME/.config/opencode/opencode-launch-env-linux.sh"
OPENCODE_LAUNCH_AGENT_LABEL="opencode-linux-env"
OPENCODE_LAUNCH_AGENT_PLIST="$TARGET_HOME/.config/opencode/opencode-linux-env.conf"

TYPESCRIPT_LSP_COMMAND="npx --yes typescript-language-server --stdio"
ESLINT_LSP_COMMAND="npx --yes vscode-eslint-language-server --stdio"
