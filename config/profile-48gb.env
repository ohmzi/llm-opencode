# 48 GB MacBook Pro local agentic coding profile.
# Edit this file first when upgrading the model, context, ports, MCP paths,
# launch env, LSPs, or LM Studio runtime packages.

PROFILE_NAME="48GB MacBook Pro Qwen3.6 MLX 8-bit agentic coding profile"
PROFILE_SLUG="48gb"
PROFILE_NOTES="Concrete OpenCode + LM Studio setup for Apple Silicon with about 48 GB RAM, fast default routing, and Qwen-backed local-coder implementation."
TARGET_USER="oiqbal"
TARGET_HOME="/Users/oiqbal"
EXPECTED_ARCH="arm64"
EXPECTED_MEM_BYTES="51539607552"
MIN_MEM_BYTES="48000000000"
MAX_MEM_BYTES="56000000000"

LMS="/Applications/LM Studio.app/Contents/Resources/app/.webpack/lms"
LMSTUDIO_HOST="127.0.0.1"
LMSTUDIO_PORT="1234"
LMSTUDIO_BASE_URL="http://127.0.0.1:1234/v1"
LMSTUDIO_MODELS_URL="http://127.0.0.1:1234/api/v0/models"
LMSTUDIO_EMBEDDING_URL="http://127.0.0.1:1234/v1/embeddings"
LMSTUDIO_VERIFIED_VERSION="0.4.15+2"
OPENCODE_VERIFIED_VERSION="1.15.12"

CHAT_ID="local-coder"
CHAT_GET_REF="froggeric/qwen3.6-27b-mlx-8bit"
CHAT_MODEL_KEY="froggeric/qwen3.6-27b-mlx-8bit"
CHAT_MODEL_INDEXED_IDENTIFIER="froggeric/qwen3.6-27b-mlx-8bit"
CHAT_MODEL_PATH="froggeric/Qwen3.6-27B-MLX-8bit"
CHAT_MODEL_FORMAT="safetensors"
CHAT_MODEL_QUANTIZATION="8bit"
CHAT_MODEL_SIZE_GB="28"
CHAT_MODEL_MIN_SYSTEM_MEMORY_GB="35"
CHAT_MODEL_DISPLAY="Qwen3.6 27B MLX 8-bit (local, 32K)"
CHAT_CONTEXT="32768"
CHAT_CONTEXT_FALLBACK_1="24576"
CHAT_CONTEXT_FALLBACK_2="16384"
CHAT_OUTPUT="4096"
CHAT_PARALLEL="1"
CHAT_GPU="max"
CHAT_TTL="3600"

FAST_ID="local-fast"
FAST_GET_REF="mlx-community/Llama-3.2-3B-Instruct-4bit"
FAST_MODEL_KEY="llama-3.2-3b-instruct"
FAST_MODEL_INDEXED_IDENTIFIER="mlx-community/Llama-3.2-3B-Instruct-4bit"
FAST_MODEL_PATH="mlx-community/Llama-3.2-3B-Instruct-4bit"
FAST_MODEL_FORMAT="safetensors"
FAST_MODEL_QUANTIZATION="4bit"
FAST_MODEL_SIZE_GB="2"
FAST_MODEL_DISPLAY="Llama 3.2 3B Instruct MLX (local, fast)"
FAST_CONTEXT="32768"
FAST_OUTPUT="1024"
FAST_PARALLEL="1"
FAST_GPU="max"
FAST_TTL="3600"

EMBED_ID="text-embedding-nomic-embed-text-v1.5"
EMBED_MODEL_KEY="text-embedding-nomic-embed-text-v1.5"
EMBED_MODEL_PATH="nomic-ai/nomic-embed-text-v1.5-GGUF/nomic-embed-text-v1.5.Q4_K_M.gguf"
EMBED_DIMENSIONS="768"
EMBED_TTL="3600"

OPENCODE_PROVIDER="lmstudio"
OPENCODE_DEFAULT_AGENT="fast"
OPENCODE_MODEL="lmstudio/local-fast"
OPENCODE_SMALL_MODEL="lmstudio/local-fast"
OPENCODE_CODER_MODEL="lmstudio/local-coder"
OPENCODE_CONFIG="$TARGET_HOME/.config/opencode/opencode.json"
OPENCODE_CONFIG_DIR="$TARGET_HOME/.config/opencode"
OPENCODE_QWEN_INSTRUCTIONS="$TARGET_HOME/.config/opencode/qwen36-instructions.md"
OPENCODE_WORKFLOW_INSTRUCTIONS="$TARGET_HOME/.config/opencode/local-coding-workflow.md"
OPENCODE_DESKTOP_STATE="$TARGET_HOME/Library/Application Support/ai.opencode.desktop/opencode.global.dat"
OPENCODE_INDEX_ROOTS="auto"
OPENCODE_INDEX_AUTODISCOVER="1"
OPENCODE_INDEX_BACKGROUND="1"
OPENCODE_INDEX_BACKGROUND_SECONDS="300"
OPENCODE_INDEX_AUTO_SYNC_SECONDS="300"
OPENCODE_INDEX_DB="$TARGET_HOME/.cache/opencode/local-code-index.sqlite3"
OPENCODE_DEV_ROOTS="auto"
OPENCODE_COMPACTION_RESERVED="10000"

LOCAL_DEV_COMMAND_TIMEOUT="120"
LOCAL_DEV_MAX_TIMEOUT="600"
LOCAL_DEV_MAX_OUTPUT_CHARS="24000"
LOCAL_DEV_MAX_TREE_ENTRIES="400"

OPENCODE_ENABLE_EXA="1"
OPENCODE_EXPERIMENTAL_LSP_TOOL="true"
OPENCODE_LAUNCH_ENV="$TARGET_HOME/.config/opencode/opencode-launch-env.sh"
OPENCODE_LAUNCH_AGENT_LABEL="com.oiqbal.opencode.env"
OPENCODE_LAUNCH_AGENT_PLIST="$TARGET_HOME/Library/LaunchAgents/com.oiqbal.opencode.env.plist"

TYPESCRIPT_LSP_COMMAND="npx --yes typescript-language-server --stdio"
ESLINT_LSP_COMMAND="npx --yes vscode-eslint-language-server --stdio"

MLX_RUNTIME_VERSION="1.8.5"
MLX_RUNTIME_NAX="mlx-llm-mac-arm64-apple-metal-nax-advsimd"
MLX_RUNTIME_STANDARD="mlx-llm-mac-arm64-apple-metal-advsimd"
LMSTUDIO_BACKENDS_DIR="$TARGET_HOME/.lmstudio/extensions/backends"
LMSTUDIO_BACKENDS_CACHE_DIR="$TARGET_HOME/.cache/lm-studio/downloads/backends"
LMSTUDIO_EXTENSION_MASTER_LIST="https://extensions.lmstudio.ai/master-lists-v2/backends-master-list-stable.json"

LMSTUDIO_EXTENSION_CPYTHON_NAME="vendor-_amphibian-cpython3.11-mac-arm64@10"
LMSTUDIO_EXTENSION_CPYTHON_URL="https://extensions.lmstudio.ai/vendor-_amphibian-cpython3.11-mac-arm64%4010.tar.gz"
LMSTUDIO_EXTENSION_CPYTHON_SHA256="9f69bc1f2a457a5d94d46913bbb6e0f4b9b2810db791457396f2827b218b8310"

LMSTUDIO_EXTENSION_APP_MLX_MAC14_NAME="vendor-_amphibian-app-mlx-generate-mac14-arm64@29"
LMSTUDIO_EXTENSION_APP_MLX_MAC14_URL="https://extensions.lmstudio.ai/vendor-_amphibian-app-mlx-generate-mac14-arm64%4029.tar.gz"
LMSTUDIO_EXTENSION_APP_MLX_MAC14_SHA256="a95e529661fe7ec48671d46cf95df50c211648a27d3bca33ec6c9fce61190a3d"

LMSTUDIO_EXTENSION_APP_MLX_MAC26_NAME="vendor-_amphibian-app-mlx-generate-mac26-arm64@28"
LMSTUDIO_EXTENSION_APP_MLX_MAC26_URL="https://extensions.lmstudio.ai/vendor-_amphibian-app-mlx-generate-mac26-arm64%4028.tar.gz"
LMSTUDIO_EXTENSION_APP_MLX_MAC26_SHA256="daae9ff30117b9f277d61c9b1e4b4bec1cd14887993acd713a08e6b0d0cee85c"

LMSTUDIO_EXTENSION_MLX_STANDARD_NAME="backend-$MLX_RUNTIME_STANDARD-$MLX_RUNTIME_VERSION"
LMSTUDIO_EXTENSION_MLX_STANDARD_URL="https://extensions.lmstudio.ai/backend-mlx-llm-mac-arm64-apple-metal-advsimd-1.8.5.tar.gz"
LMSTUDIO_EXTENSION_MLX_STANDARD_SHA256="cd69c67d836826c5d951dcbb28f93cdf87067e6ae34e286ce913d535eab73183"

LMSTUDIO_EXTENSION_MLX_NAX_NAME="backend-$MLX_RUNTIME_NAX-$MLX_RUNTIME_VERSION"
LMSTUDIO_EXTENSION_MLX_NAX_URL="https://extensions.lmstudio.ai/backend-mlx-llm-mac-arm64-apple-metal-nax-advsimd-1.8.5.tar.gz"
