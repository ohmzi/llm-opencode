{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "lmstudio"
  ],
  "default_agent": "fast",
  "instructions": [
    "/Users/oiqbal/.config/opencode/qwen36-instructions.md",
    "/Users/oiqbal/.config/opencode/local-coding-workflow.md"
  ],
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "whitelist": [
        "local-coder",
        "local-fast"
      ],
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "lmstudio",
        "timeout": 900000,
        "chunkTimeout": 900000
      },
      "models": {
        "local-coder": {
          "name": "Qwen3.6 27B MLX 8-bit (local, 32K)",
          "attachment": true,
          "reasoning": false,
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "local-fast": {
          "name": "Llama 3.2 3B Instruct MLX (local, fast)",
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 1024
          }
        }
      }
    }
  },
  "model": "lmstudio/local-fast",
  "small_model": "lmstudio/local-fast",
  "share": "disabled",
  "autoupdate": "notify",
  "formatter": true,
  "snapshot": true,
  "shell": "/bin/zsh",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "tool_output": {
    "max_lines": 500,
    "max_bytes": 24000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".gradle/**",
      ".idea/**",
      ".vscode/**",
      ".cache/**",
      ".dart_tool/**",
      ".lmstudio/**",
      ".next/**",
      ".swiftpm/**",
      ".venv/**",
      "DerivedData/**",
      "Pods/**",
      "build/**",
      "dist/**",
      "node_modules/**",
      "out/**",
      "target/**",
      "__pycache__/**"
    ]
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls": "allow",
      "ls *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git rev-parse*": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "sed -n *": "allow",
      "npm test*": "allow",
      "npm run test*": "allow",
      "pnpm test*": "allow",
      "pnpm run test*": "allow",
      "yarn test*": "allow",
      "python -m pytest*": "allow",
      "pytest*": "allow",
      "swift test*": "allow",
      "./gradlew test*": "allow",
      "gradle test*": "allow",
      "go test*": "allow",
      "cargo test*": "allow",
      "xcodebuild -list*": "allow"
    },
    "task": "allow",
    "external_directory": "ask",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "repo_clone": "ask",
    "repo_overview": "allow",
    "lsp": "allow",
    "doom_loop": "ask",
    "skill": "allow",
    "local_code_index_*": "allow",
    "local_dev_tools_project_overview": "allow",
    "local_dev_tools_git_status": "allow",
    "local_dev_tools_file_tree": "allow",
    "local_dev_tools_dependency_summary": "allow",
    "local_dev_tools_run_command": "ask",
    "local_dev_tools_debug_command": "ask",
    "context7_*": "allow",
    "gh_grep_*": "allow"
  },
  "agent": {
    "fast": {
      "description": "Default fast no-tool agent for quick answers and sanity checks.",
      "mode": "primary",
      "model": "lmstudio/local-fast",
      "temperature": 0.1,
      "steps": 4,
      "prompt": "You are the fast default OpenCode agent. Answer direct questions immediately without tools. If the user asks for code edits, tests, debugging, repository research, or MCP-backed work, tell them to use /implement, /explain, /research, /debug, or select Build. Do not attempt tool calls.",
      "permission": {
        "read": "deny",
        "edit": "deny",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "bash": "deny",
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "skill": "deny",
        "local_code_index_*": "deny",
        "local_dev_tools_*": "deny",
        "context7_*": "deny",
        "gh_grep_*": "deny"
      }
    },
    "explain": {
      "description": "Read-only explanation agent for answering codebase and behavior questions with tight context.",
      "mode": "primary",
      "model": "lmstudio/local-fast",
      "temperature": 0.1,
      "steps": 8,
      "prompt": "Explain general concepts concisely without tools. Do not call tools, do not print tool-call syntax, and do not use subagents. For project-specific behavior, do not guess; say that exact repository evidence needs /research for MCP-backed discovery.",
      "permission": {
        "read": "deny",
        "edit": "deny",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "bash": {
          "*": "deny"
        },
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "skill": "deny",
        "local_code_index_code_index_search": "deny",
        "local_code_index_*": "deny",
        "local_dev_tools_project_overview": "deny",
        "local_dev_tools_git_status": "deny",
        "local_dev_tools_file_tree": "deny",
        "local_dev_tools_dependency_summary": "deny",
        "local_dev_tools_run_command": "deny",
        "local_dev_tools_debug_command": "deny",
        "local_dev_tools_*": "deny",
        "context7_*": "deny",
        "gh_grep_*": "deny"
      }
    },
    "indexer": {
      "description": "Read-only local semantic index inspection and refresh helper.",
      "mode": "primary",
      "model": "lmstudio/local-coder",
      "temperature": 0.1,
      "steps": 8,
      "prompt": "Inspect or refresh the local semantic index only. Use local_code_index status first, refresh only when requested or clearly needed, then summarize index health. Never repeat identical tool calls.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "local_code_index_*": "allow",
        "local_dev_tools_project_overview": "allow",
        "local_dev_tools_git_status": "allow",
        "local_dev_tools_run_command": "deny",
        "local_dev_tools_debug_command": "deny"
      }
    },
    "build": {
      "description": "Default coding agent for implementing, editing, testing, debugging, and coordinating subagents.",
      "mode": "primary",
      "model": "lmstudio/local-coder",
      "temperature": 0.2,
      "steps": 18,
      "permission": {
        "task": {
          "*": "allow"
        },
        "local_code_index_*": "deny",
        "local_dev_tools_*": "deny",
        "context7_*": "deny",
        "gh_grep_*": "deny"
      }
    },
    "plan": {
      "description": "Read-only planning agent for architecture, sequencing, and risk review before implementation.",
      "mode": "primary",
      "model": "lmstudio/local-coder",
      "temperature": 0.1,
      "steps": 10,
      "prompt": "You are a planning agent. Inspect context, decompose the work, identify risks and verification, but do not edit files.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "local_dev_tools_run_command": "deny",
        "local_dev_tools_debug_command": "deny"
      }
    },
    "codebase-researcher": {
      "description": "Find where behavior lives using local RAG, grep/glob/read, file tree, dependency summaries, and LSP.",
      "mode": "subagent",
      "model": "lmstudio/local-coder",
      "temperature": 0.1,
      "steps": 10,
      "color": "info",
      "prompt": "Research the codebase without editing. Use at most one local_code_index semantic search and one read pass before returning evidence. Never call the same tool twice with identical input in one turn. Return precise file paths, symbols, and next steps.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny",
        "local_code_index_*": "allow",
        "local_dev_tools_project_overview": "allow",
        "local_dev_tools_git_status": "allow",
        "local_dev_tools_file_tree": "allow",
        "local_dev_tools_dependency_summary": "allow",
        "local_dev_tools_run_command": "deny",
        "local_dev_tools_debug_command": "deny"
      }
    },
    "debugger": {
      "description": "Debug failing commands, tests, runtime errors, stack traces, and reproduction paths.",
      "mode": "subagent",
      "model": "lmstudio/local-coder",
      "temperature": 0.1,
      "steps": 12,
      "color": "warning",
      "prompt": "You are a debugging agent. Reproduce narrowly, capture command output, isolate the failure, and propose or hand back the minimal fix. Do not edit files unless the primary agent asks you to.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "yarn test*": "allow",
          "python -m pytest*": "allow",
          "pytest*": "allow",
          "swift test*": "allow",
          "./gradlew test*": "allow",
          "go test*": "allow",
          "cargo test*": "allow"
        },
        "task": "deny",
        "local_dev_tools_debug_command": "ask",
        "local_dev_tools_run_command": "ask"
      }
    },
    "test-runner": {
      "description": "Choose and run the narrowest useful validation commands for a project.",
      "mode": "subagent",
      "model": "lmstudio/local-coder",
      "temperature": 0.1,
      "steps": 12,
      "color": "success",
      "prompt": "You are a test runner. Detect the project type, choose the smallest relevant verification command first, run it, and report exact failures and next commands.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "npm test*": "allow",
          "npm run test*": "allow",
          "pnpm test*": "allow",
          "pnpm run test*": "allow",
          "yarn test*": "allow",
          "python -m pytest*": "allow",
          "pytest*": "allow",
          "swift test*": "allow",
          "./gradlew test*": "allow",
          "gradle test*": "allow",
          "go test*": "allow",
          "cargo test*": "allow",
          "xcodebuild -list*": "allow"
        },
        "task": "deny",
        "local_dev_tools_project_overview": "allow",
        "local_dev_tools_debug_command": "ask",
        "local_dev_tools_run_command": "ask"
      }
    },
    "code-reviewer": {
      "description": "Review diffs and code paths for bugs, regressions, maintainability, missing tests, and security concerns.",
      "mode": "subagent",
      "model": "lmstudio/local-coder",
      "temperature": 0.1,
      "steps": 12,
      "color": "accent",
      "prompt": "You are a code-review agent. Lead with concrete findings ordered by severity. Include file paths and why each issue matters. Do not edit files.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny",
        "local_code_index_*": "allow",
        "local_dev_tools_git_status": "allow",
        "local_dev_tools_run_command": "deny",
        "local_dev_tools_debug_command": "deny"
      }
    },
    "doc-researcher": {
      "description": "Look up current framework/library docs and real-world code examples without editing.",
      "mode": "subagent",
      "model": "lmstudio/local-coder",
      "temperature": 0.1,
      "steps": 10,
      "color": "secondary",
      "prompt": "You are a documentation research agent. Use context7 for official/current docs and gh_grep for real-world examples. Return concise implementation guidance with source names.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "context7_*": "allow",
        "gh_grep_*": "allow"
      }
    },
    "security-auditor": {
      "description": "Read-only security review for input validation, auth, secrets, injection, unsafe filesystem/shell use, and dependency risk.",
      "mode": "subagent",
      "model": "lmstudio/local-coder",
      "temperature": 0.1,
      "steps": 12,
      "color": "error",
      "prompt": "You are a security auditor. Trace source-to-sink risk, calibrate severity, and avoid speculative findings. Do not edit files.",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny",
        "local_code_index_*": "allow",
        "local_dev_tools_project_overview": "allow",
        "local_dev_tools_dependency_summary": "allow",
        "local_dev_tools_run_command": "deny",
        "local_dev_tools_debug_command": "deny"
      }
    }
  },
  "command": {
    "explain": {
      "description": "Explain codebase behavior with tight read-only context",
      "agent": "explain",
      "template": "Explain this request concisely without tools. Do not call tools or print tool-call syntax. If this asks about project-specific behavior, do not guess; say to use /research for exact repository evidence. Request: $ARGUMENTS"
    },
    "research": {
      "description": "Research codebase context with local RAG",
      "agent": "codebase-researcher",
      "subtask": true,
      "template": "Research this request using local_code_index, grep/glob/read, local_dev_tools, and LSP if useful. Return concrete files, symbols, and next steps: $ARGUMENTS"
    },
    "debug": {
      "description": "Debug a failure or command",
      "agent": "debugger",
      "subtask": true,
      "template": "Debug this issue. Reproduce narrowly when possible, use local_dev_tools debug_command for command output, and return likely root cause plus fix options: $ARGUMENTS"
    },
    "test": {
      "description": "Run narrow validation",
      "agent": "test-runner",
      "subtask": true,
      "template": "Detect the project type, choose and run the narrowest relevant validation first, then report exact failures and next verification steps. Scope: $ARGUMENTS"
    },
    "review": {
      "description": "Review current changes or target files",
      "agent": "code-reviewer",
      "subtask": true,
      "template": "Review the current changes or requested target. Prioritize bugs, regressions, security issues, and missing tests. Scope: $ARGUMENTS"
    },
    "docs": {
      "description": "Look up current docs and examples",
      "agent": "doc-researcher",
      "subtask": true,
      "template": "Research current docs and real-world examples for: $ARGUMENTS"
    },
    "security": {
      "description": "Run read-only security audit",
      "agent": "security-auditor",
      "subtask": true,
      "template": "Run a read-only security audit for this scope. Validate concrete source-to-sink risks and avoid speculation: $ARGUMENTS"
    },
    "index": {
      "description": "Inspect or refresh local semantic index",
      "agent": "indexer",
      "template": "Use local_code_index. First run code_index_status. If a project is open or a root is specified, refresh the index as needed, then summarize index health. Scope: $ARGUMENTS"
    },
    "implement": {
      "description": "Implement with research, edit, and verification",
      "agent": "build",
      "template": "Implement this request end to end. Use a research subagent if the code path is unclear, edit with OpenCode's edit/apply_patch tools, then run the narrowest relevant verification. Request: $ARGUMENTS"
    }
  },
  "lsp": {
    "typescript": {
      "command": [
        "npx",
        "--yes",
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs"
      ]
    },
    "eslint": {
      "command": [
        "npx",
        "--yes",
        "vscode-eslint-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs"
      ]
    }
  },
  "mcp": {
    "local_code_index": {
      "type": "local",
      "command": [
        "/usr/bin/python3",
        "/Users/oiqbal/.config/opencode/mcp/local_code_index.py"
      ],
      "environment": {
        "OPENCODE_INDEX_ROOTS": "auto",
        "OPENCODE_INDEX_AUTODISCOVER": "1",
        "OPENCODE_DESKTOP_STATE": "/Users/oiqbal/Library/Application Support/ai.opencode.desktop/opencode.global.dat",
        "OPENCODE_INDEX_BACKGROUND": "1",
        "OPENCODE_INDEX_BACKGROUND_SECONDS": "300",
        "OPENCODE_INDEX_AUTO_SYNC_SECONDS": "300",
        "OPENCODE_INDEX_DB": "/Users/oiqbal/.cache/opencode/local-code-index.sqlite3",
        "LMSTUDIO_EMBEDDING_URL": "http://127.0.0.1:1234/v1/embeddings",
        "LMSTUDIO_EMBEDDING_MODEL": "text-embedding-nomic-embed-text-v1.5"
      },
      "enabled": true,
      "timeout": 600000
    },
    "local_dev_tools": {
      "type": "local",
      "command": [
        "/usr/bin/python3",
        "/Users/oiqbal/.config/opencode/mcp/local_dev_tools.py"
      ],
      "environment": {
        "OPENCODE_DEV_ROOTS": "auto",
        "OPENCODE_DESKTOP_STATE": "/Users/oiqbal/Library/Application Support/ai.opencode.desktop/opencode.global.dat",
        "LOCAL_DEV_COMMAND_TIMEOUT": "120",
        "LOCAL_DEV_MAX_TIMEOUT": "600",
        "LOCAL_DEV_MAX_OUTPUT_CHARS": "24000",
        "LOCAL_DEV_MAX_TREE_ENTRIES": "400"
      },
      "enabled": true,
      "timeout": 600000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 600000
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 600000
    }
  },
  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 2000,
      "max_height": 2000,
      "max_base64_bytes": 8388608
    }
  }
}
